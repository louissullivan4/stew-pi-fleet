{
  "name": "pi-fleet",
  "version": "1.0.0",
  "description": "Raspberry Pi Fleet Management Dashboard",
  "main": "src/server/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server/index.js",
    "dev:server": "nodemon src/server/index.js",
    "dev:client": "cd src/client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd src/client && npm run build",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "ssh2": "^1.15.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
