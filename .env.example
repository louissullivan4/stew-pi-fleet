# Application
NODE_ENV=production
PORT=3001

# JWT — change this to a long random string in production
JWT_SECRET=change-this-to-a-random-secret-string
JWT_EXPIRES_IN=24h

# Dashboard credentials
DASHBOARD_USERNAME=ls
DASHBOARD_PASSWORD=stewpi

# SSH — path to the private key used to connect to managed Pis
SSH_KEY_PATH=/data/ssh/pi_fleet_rsa

# Paths (used inside Docker; override for local dev)
CONFIG_PATH=/data/config/pis.yaml
DB_PATH=/data/db/fleet.db

# Notifications — all optional
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
